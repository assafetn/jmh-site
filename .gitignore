# This repo intentionally tracks ONLY the deliverable: the self-contained V2 site
# and the illustrations it loads. Everything else (React scaffold, experiments,
# docs, PNG originals, node_modules, local config) stays on disk but out of git.

# Ignore everything at the root...
/*

# ...except the deliverable and the files that support it:
!/.gitignore
!/JMH_Website_V2.html
!/assets/

# Inside assets/, keep only the illustrations folder...
/assets/*
!/assets/illustrations/

# ...and inside that, only the WebP images the site actually loads.
/assets/illustrations/*
!/assets/illustrations/*.webp
